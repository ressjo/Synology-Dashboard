# Synology Dashboard — Secrets Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Synology DSM password for the dashboard user
SYNO_PASSWORD=

# SSH password for the dashboard user (or use ssh.key_path in config.yaml)
SSH_PASSWORD=

# Paperless-ngx API token (Settings → API Token)
PAPERLESS_TOKEN=

# Portainer password
PORTAINER_PASSWORD=
